# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Anthropic (Claude)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Google Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Grok (xAI)
GROK_API_KEY=
GROK_MODEL=grok-3

# Optional: Groq (cheap inference — different from Grok/xAI)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Default provider for agents (openai | anthropic | gemini | grok)
DEFAULT_PROVIDER=openai

# Delivery
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# IMAP (inbox reader — uses SMTP_USER/SMTP_PASS for auth)
IMAP_HOST=imappro.zohocloud.ca
IMAP_PORT=993

# Billing — Stripe
# Get keys from: https://dashboard.stripe.com/test/apikeys
STRIPE_API_KEY=
STRIPE_PUBLIC_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_LIVE=0

# Resonance Energy Integration (optional)
AAC_ROOT=C:\dev\AAC_fresh
NCL_DATA_PATH=
NCC_RELAY_URL=http://127.0.0.1:8787
