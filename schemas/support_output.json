{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Support Resolver Output",
  "description": "Output schema for the Support Resolver Agent.",
  "type": "object",
  "required": ["category", "severity", "draft_reply", "escalation"],
  "properties": {
    "category": {
      "type": "string",
      "enum": ["billing", "technical", "onboarding", "bug", "feature_request", "account", "other"]
    },
    "severity": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "sentiment": {
      "type": "string",
      "enum": ["calm", "frustrated", "angry"]
    },
    "summary": { "type": "string" },
    "draft_reply": { "type": "string" },
    "next_actions": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "action": {
            "type": "string",
            "enum": ["ask_clarifying_question", "provide_steps", "create_ticket", "escalate", "close"]
          },
          "details": { "type": "string" }
        }
      }
    },
    "escalation": {
      "type": "object",
      "properties": {
        "required": { "type": "boolean" },
        "reason": { "type": "string" },
        "team": { "type": "string", "enum": ["support", "engineering", "billing", "legal", "management"] }
      }
    },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "citations": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "source": { "type": "string" },
          "link_or_id": { "type": "string" },
          "quote": { "type": "string" }
        }
      }
    }
  }
}
