{
  "name": "dl-memory-hot-reload",
  "displayName": "DIGITAL LABOUR Memory Hot Reload",
  "description": "Hot code reloading for DIGITAL LABOUR memory systems with real-time blank prevention",
  "version": "2.0.0",
  "publisher": "bit-rage-labour",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:digitalLabourMemory.startHotReload",
    "workspaceContains:unified_memory_doctrine_system.py"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "digitalLabourMemory.startHotReload",
        "title": "Start Memory Hot Reload",
        "category": "DIGITAL LABOUR"
      },
      {
        "command": "digitalLabourMemory.stopHotReload",
        "title": "Stop Memory Hot Reload",
        "category": "DIGITAL LABOUR"
      },
      {
        "command": "digitalLabourMemory.showMemoryStatus",
        "title": "Show Memory Status",
        "category": "DIGITAL LABOUR"
      },
      {
        "command": "digitalLabourMemory.forceReload",
        "title": "Force Memory Reload",
        "category": "DIGITAL LABOUR"
      }
    ],
    "keybindings": [
      {
        "command": "digitalLabourMemory.forceReload",
        "key": "ctrl+shift+m",
        "mac": "cmd+shift+m",
        "when": "workspaceContains:unified_memory_doctrine_system.py"
      }
    ],
    "configuration": {
      "title": "DIGITAL LABOUR Memory Hot Reload",
      "properties": {
        "digitalLabourMemory.autoStart": {
          "type": "boolean",
          "default": true,
          "description": "Automatically start memory hot reload when workspace opens"
        },
        "digitalLabourMemory.reloadInterval": {
          "type": "number",
          "default": 2000,
          "minimum": 500,
          "maximum": 10000,
          "description": "Interval in milliseconds to check for code changes"
        },
        "digitalLabourMemory.showNotifications": {
          "type": "boolean",
          "default": true,
          "description": "Show notifications for memory reload events"
        }
      }
    },
    "statusBar": [
      {
        "id": "memory-status",
        "text": "$(database) Memory: $(check)",
        "tooltip": "DIGITAL LABOUR Memory System Status",
        "command": "digitalLabourMemory.showMemoryStatus",
        "alignment": "right",
        "priority": 100
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/vscode": "^1.74.0",
    "@types/node": "16.x",
    "eslint": "^8.28.0",
    "typescript": "^4.9.0"
  }
}