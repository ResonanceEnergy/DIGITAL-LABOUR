[master]
# Digital Labour workspace pylint configuration
# Suppresses non-critical style warnings to focus on real bugs
ignore-paths=repos,Digital-Labour,openclaw,openclaw-workspace,nextjs-openai-integration

[MESSAGES CONTROL]
# Disable noisy stylistic warnings that don't indicate bugs:
# W0703: broad-except - except Exception is acceptable for top-level handlers
# W1203: logging-fstring-interpolation - f-strings in logging are fine in modern Python
# W1514: unspecified-encoding - encoding defaults are acceptable for local-only files
# W0621: redefined-outer-name - common in Flask route handlers and nested functions
# W0404: reimported - sometimes needed for conditional imports
# W0611: unused-import - many imports are used dynamically or for type checking
# W0612: unused-variable - caught exception variables 'e' are often intentional
# C0114: missing-module-docstring
# C0115: missing-class-docstring
# C0116: missing-function-docstring
# R0903: too-few-public-methods
# R0913: too-many-arguments
# R0914: too-many-locals
# R0915: too-many-statements
# C0301: line-too-long
# W0105: pointless-string-statement
# W0602: global-variable-not-assigned
# W0707: raise-missing-from
# E0602: undefined-variable (conditional imports / dynamic usage)
# W0622: redefined-builtin
# W0108: unnecessary-lambda
# E1111: assignment-from-no-return
# E1123: unexpected-keyword-arg
# W0632: unbalanced-dict-unpacking
# E0601: used-before-assignment
# W1309: using-f-string-without-interpolation
disable=W0702,W0703,W1203,W1514,W0621,W0404,W0611,W0612,C0114,C0115,C0116,R0903,R0913,R0914,R0915,C0301,W0613,W0107,E0401,E0611,E1136,W0221,W0223,W0231,W0246,C0103,C0209,R0801,R0902,R0911,R0401,W0603,W0212,W0511,W1510,W0104,R1732,E1101,W0201,E1120,W0631,W0106,W0105,W0602,W0707,E0602,W0622,W0108,E1111,E1123,W0632,E0601,W1309

[FORMAT]
max-line-length=120

[BASIC]
good-names=i,j,k,e,f,fh,db,id,_

[DESIGN]
max-args=10
max-locals=25
